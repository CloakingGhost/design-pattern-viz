# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Frontend (Next.js) ───────────────────────────────────────────
node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/package-lock.json

# testing
frontend/coverage

# next.js
frontend/.next/
frontend/out/

# production
frontend/build

# typescript
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# vercel
frontend/.vercel

# ─── Backend (Spring Boot) ────────────────────────────────────────
backend/build
backend/.gradle
backend/out
backend/*.class

# ─── Shared / Misc ───────────────────────────────────────────────
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# etc
*.txt